# Copy this file to .env and fill in the real values.
# Never commit the populated .env (it is gitignored).
#
# These three are the Supabase publishable (anon) credentials used by the
# browser bundle. They are safe to expose to clients but should still live
# in .env so the repo can be re-pointed at a different Supabase project
# without code changes.

VITE_SUPABASE_PROJECT_ID=""
VITE_SUPABASE_PUBLISHABLE_KEY=""
VITE_SUPABASE_URL=""

# Meta Pixel (public marketing routes only, after cookie consent). Leave empty to disable.
VITE_META_PIXEL_ID=""

# Supabase Edge Function secrets (set in Dashboard → Edge Functions → Secrets):
# RESEND_API_KEY — transactional email
# STRIPE_SECRET_KEY, STRIPE_WEBHOOK_SECRET — payments
# CRON_SECRET — scheduled intake reminders
# STAFF_NOTIFICATION_PHONE — staff alert destination (if re-enabled later)
# OPENAI_API_KEY — staff help AI (staff-help-ai); Phase B1 will migrate recommend-lab-panel + parse-zrt-labs
# OPENAI_MODEL — optional, default gpt-4o-mini (use gpt-4o for PDF vision in parse-zrt-labs later)
# LOVABLE_API_KEY — legacy; still used by recommend-lab-panel + parse-zrt-labs until Phase B1 (see docs/CLINICAL_AI_ROADMAP.md)
# PDFSHIFT_API_KEY — required for Rx fax PDF generation (send-rx-fax)
# TELNYX_API_KEY, TELNYX_FAX_CONNECTION_ID, TELNYX_FAX_FROM_NUMBER — Supabase secrets only (fax)
# APP_BASE_URL — production site origin for intake magic links (default https://elevatedhealthaugusta.com)
#
# Patient/staff SMS + voice: Twilio (Supabase Edge Function secrets):
# TWILIO_ACCOUNT_SID
# TWILIO_AUTH_TOKEN
# TWILIO_MESSAGING_SERVICE_SID     — preferred; attach your number + 10DLC campaign
# TWILIO_SMS_FROM_NUMBER           — fallback E.164, e.g. +17067603470
# TWILIO_CLINIC_PHONE              — caller ID for voice (default +17067603470)
# TWILIO_STATUS_CALLBACK_URL       — https://<ref>.supabase.co/functions/v1/twilio-status-callback
# TWILIO_INBOUND_SMS_WEBHOOK_URL   — https://<ref>.supabase.co/functions/v1/twilio-inbound-sms
# TWILIO_VOICE_WEBHOOK_URL         — https://<ref>.supabase.co/functions/v1/twilio-voice
# TWILIO_VOICE_FORWARD_NUMBERS     — comma-separated staff cell numbers for call routing
# STAFF_NOTIFICATION_PHONES        — comma-separated numbers for inbound SMS alerts
